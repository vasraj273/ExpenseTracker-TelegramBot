# Copy this file to .env and fill in the values.

# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user id.
# Leave blank the first time, run the bot, send it /myid, then paste the id here.
OWNER_ID=

# Optional: path to the SQLite database file (defaults to expenses.db)
DB_PATH=expenses.db
