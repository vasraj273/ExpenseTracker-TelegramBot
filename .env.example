# Copy this file to .env and fill in the values.

# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user id.
# Leave blank the first time, run the bot, send it /myid, then paste the id here.
OWNER_ID=

# Only for the PythonAnywhere (webhook) deployment.
# A long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
WEBHOOK_SECRET=

# Optional: override the SQLite database path (defaults to expenses.db next to the code)
DB_PATH=
